{
  "name": "dataharvest-pipeline",
  "version": "1.0.0",
  "description": "Production-grade data pipeline for scraping, transforming, and persisting e-commerce and news data",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "test:coverage": "vitest run --coverage",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts"
  },
  "keywords": [],
  "author": "Ian Cler Renaud",
  "license": "ISC",
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@testcontainers/redis": "^12.0.3",
    "@types/basic-auth": "^1.1.8",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@bull-board/api": "^8.0.1",
    "@bull-board/express": "^8.0.1",
    "@bull-board/ui": "^8.0.1",
    "axios": "^1.18.1",
    "basic-auth": "^2.0.1",
    "bullmq": "^5.79.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "knex": "^3.2.10",
    "node-cron": "^4.5.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "playwright": "^1.61.1",
    "prom-client": "^15.1.3",
    "robots-parser": "^3.0.1",
    "swagger-ui-express": "^5.0.1",
