PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dataharvest
REDIS_URL=redis://localhost:6379
SCRAPER_CONCURRENCY=3
TRANSFORMER_CONCURRENCY=5
PERSISTER_CONCURRENCY=2
RATE_LIMIT_DELAY_MS=1000
REQUEST_TIMEOUT_MS=10000
BOOKS_CRON=0 2 * * *
HN_CRON=*/15 * * * *
LOG_LEVEL=info
ADMIN_USER=admin
ADMIN_PASSWORD=admin
PLAYWRIGHT_FALLBACK_ENABLED=true